# Rollback front door — the pre-launch behaviour of the box (apex 301 + holding
# page), reconstructed in-repo so the deploy/Caddyfile swap is reversible even
# if the on-server snapshot step was skipped (deploy/README.md, Rollback).
# Serving this file restores "coming soon" without touching certificates:
# Caddy reuses its already-issued certs across config reloads.

talyvor.com {
	redir https://app.talyvor.com{uri} 301
}

app.talyvor.com {
	respond "Talyvor app — coming soon"
}
