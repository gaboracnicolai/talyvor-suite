# /etc/talyvor/bff.env — the BFF's entire runtime surface (chmod 0600).
# Every value here is documented, with its failure mode, in deploy/README.md §4.
# The BFF fails closed: a missing required value refuses to start and names itself.

# ── Bind & mode ──────────────────────────────────────────────────────────────
# Loopback: Caddy is the only network-facing process.
BFF_ADDR=127.0.0.1:8787
# Production posture. ("disabled" is the loopback-only dev mode.)
BFF_AUTH_MODE=oidc

# ── OIDC (all five required in oidc mode) ────────────────────────────────────
# The browser-facing origin. Bare origin, https, no path — it derives the
# redirect URI (<origin>/auth/callback) and scopes the __Host- session cookie.
BFF_PUBLIC_BASE_URL=https://app.talyvor.com
# The issuer. Google (recommended for the trial): https://accounts.google.com
# The BFF discovers it at boot; the BROWSER must be able to reach it too.
OIDC_ISSUER=https://accounts.google.com
# The confidential client registered at the IdP, with redirect URI EXACTLY
# https://app.talyvor.com/auth/callback
OIDC_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
OIDC_CLIENT_SECRET=REPLACE_ME
# Comma-separated trial allowlist (matched lower-cased against the id_token
# email; unverified emails are refused). "*" alone = any issuer identity.
OIDC_ALLOWED_EMAILS=you@example.com,teammate@example.com
# Optional; default 12h. Sessions are in-memory: a BFF restart signs everyone out.
#BFF_SESSION_TTL=12h

# ── Lens (both required, always) ─────────────────────────────────────────────
# https for a remote Lens box — ENFORCED at boot (the workspace key rides every
# request to it; http is allowed only on loopback, for dev).
LENS_BASE_URL=https://REPLACE_ME_LENS_HOST
LENS_WORKSPACE_KEY=tlv_ws_REPLACE_ME
LENS_WORKSPACE_ID=REPLACE_ME

# ── Track (optional trio: all three or none; oidc mode only) ─────────────────
# Unset ⇒ /api/track/* and /api/members answer 503; the rest of the app works.
# TRACK_GATEWAY_SECRET must equal the GATEWAY_AUTH_SECRET Track itself runs with.
# Trial users must also be MEMBERS of this workspace (X-User-Email is the join key).
#TRACK_BASE_URL=
#TRACK_GATEWAY_SECRET=
#TRACK_WORKSPACE_ID=

# ── Docs (optional trio: all three or none; oidc mode only) ──────────────────
# Unset ⇒ /api/docs/* answers 503.
#DOCS_BASE_URL=
#DOCS_GATEWAY_SECRET=
#DOCS_WORKSPACE_ID=
